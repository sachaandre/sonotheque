<div id="<%= dom_id song %>">
  <p>
    <strong>Title:</strong>
    <%= song.title %>
  </p>

  <% if song.audio_file.attached? %>
    <p>
      <strong>Ecouter le morceau :</strong>
      <audio controls>
        <source src="<%= url_for(song.audio_file) %>" type="audio/mpeg">
      </audio>
    </p>

    <p>
      <strong>Nom du fichier :</strong>
      <%= song.audio_file.filename %>
    </p>
  <% else %>
    <p class="text-gray-500">Aucun fichier audio</p>
  <% end %>

  <p>
    <strong>Duration seconds:</strong>
    <%= song.duration_seconds %>
  </p>

  <p>
    <strong>Year:</strong>
    <%= song.year %>
  </p>

  <p>
    <strong>Play count:</strong>
    <%= song.play_count %>
  </p>

  <p>
    <strong>Notes:</strong>
    <%= song.notes %>
  </p>
</div>