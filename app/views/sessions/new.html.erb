<div class="max-w-md mx-auto mt-20">
  <div class="bg-white rounded-lg shadow-lg p-8">
    <h1 class="text-2xl font-bold text-purple-800 mb-6">Sonotheque</h1>
    
    <%= form_with url: login_path, method: :post, local: true do |f| %>
      <div class="mb-4">
        <%= f.label :password, "Mot de passe" %>
        <%= f.password_field :password, class: "w-full px-4 py-2 border border-gray-300 rounded-lg" %>
      </div>
      <%= f.submit "Connexion", class: "w-full bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 rounded-lg" %>
    <% end %>
  </div>
</div>
